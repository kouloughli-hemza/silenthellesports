# =============================================================================
# Supabase
# =============================================================================
# Project URL (e.g. https://xxxxx.supabase.co) - found in Supabase dashboard
# Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=

# Anon (public) key - safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key - SERVER ONLY, never expose to the browser
# Bypasses RLS, used by admin actions and the Liquipedia seeder
SUPABASE_SERVICE_ROLE_KEY=

# Project ref (e.g. xxxxxxxxxxxxxxxxxxxxx) - used by `npm run db:types`
SUPABASE_PROJECT_REF=

# =============================================================================
# Yalidine (cash-on-delivery shipping for Algeria)
# =============================================================================
# If both ID and TOKEN are unset, the app uses MockYalidineService
# (full functionality with realistic Algerian wilaya/commune fixtures)
# Get credentials from https://yalidine.app
YALIDINE_API_ID=
YALIDINE_API_TOKEN=

# Default sender wilaya code (16 = Alger). Admin-configurable in dashboard.
YALIDINE_FROM_WILAYA_CODE=16

# Webhook shared secret. Set the same value in your Yalidine dashboard webhook URL
# (`?token=...`) so only Yalidine can post status updates to /api/webhooks/yalidine.
YALIDINE_WEBHOOK_TOKEN=

# Vercel Cron secret — auto-set by Vercel. Required if you set it manually.
CRON_SECRET=

# =============================================================================
# Email (Resend - order/event/giveaway confirmations)
# =============================================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=Silent Hell <noreply@silenthellesports.com>
# Where contact-form submissions are routed.
CONTACT_TO_EMAIL=support@silenthellesports.com

# =============================================================================
# Error tracking (Sentry)
# =============================================================================
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# =============================================================================
# Admin bootstrap
# =============================================================================
# The first user to sign up with this exact email is auto-promoted to admin
# (enforced by a Postgres trigger). After that, only admins can promote others.
ADMIN_BOOTSTRAP_EMAIL=

# =============================================================================
# Site
# =============================================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
